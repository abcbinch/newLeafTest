<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>방명록 기록하기</title>
  </head>
  <body>
    <h2>방명록 페이지</h2>
    <form action="/visit-form" method="post" name="visitor" id="visitor">
      <fieldset>
        <legend>방명록 등록</legend>
        <input type="text" placeholder="사용자 이름" /><br />
        <input type="text" placeholder="간단 방명록 작성" /><br />
        <input type="button" value="방명록 등록" />
      </fieldset>
    </form>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>작성자</th>
          <th>방명록</th>
          <th>수정</th>
          <th>삭제</th>
        </tr>
      </thead>
      <tbody>
        <% for(let i=0; i< data.length; i++){ %>
        <tr id="tr_<%= data[i].id %>">
          <td><%= data[i].id %></td>
          <td><%= data[i].name %></td>
          <td><%= data[i].comment %></td>
          <td><button type="button">수정</button></td>
          <td><button type="button">삭제</button></td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </body>
</html>
